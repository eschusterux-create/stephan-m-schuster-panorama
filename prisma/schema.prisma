generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Document {
  id        Int      @id @default(autoincrement())
  title     String
  fileData  Bytes
  fileName  String
  mimeType  String   @default("application/pdf")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
